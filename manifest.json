{
  "manifest_version": 3,

  "name": "URL Sharer",
  "description": "Share any webpage to WhatsApp, Twitter, LinkedIn, Telegram, Reddit & 12 more platforms — one click, zero friction.",
  "version": "1.7",
  "author": "Yuvaraj V (aka Shivaraj)",

  "browser_specific_settings": {
    "gecko": {
      "id": "{93dbc0d9-2f77-4aa8-a727-8dca5ebeb917}",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_icon": "icons/icon.png",
    "default_popup": "index.html",
    "default_title": "URL Sharer - Click And Share !"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "scripts": ["background-script.js"],
    "service_worker": "background-script.js"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ]
}