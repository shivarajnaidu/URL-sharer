{
  "name": "url-sharer",
  "version": "1.7.6",
  "description": "Share Everything You Want To Share",
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "scripts": {
    "build:vendor": "esbuild node_modules/qrcode/lib/browser.js --bundle --outfile=js/vendor/qrcode.js --format=esm --minify",
    "pack": "npm run build:vendor && mkdir -p dist && zip -r dist/url-sharer-$npm_package_version.zip manifest.json popup.html background-script.js css/ icons/ js/ LICENSE -x 'js/bundle.js'",
    "postinstall": "npm run build:vendor",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shivarajnaidu/URL-sharer.git"
  },
  "author": "Yuvaraj (aka Shivaraj)",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/shivarajnaidu/URL-sharer/issues"
  },
  "homepage": "https://addons.mozilla.org/en-US/firefox/addon/url-sharer/",
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
